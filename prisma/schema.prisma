// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// Enums
// ------------------------------------------------------

enum OutreachLocation {
  JOHOR_BAHRU
  ISKANDAR_PUTERI
  TAMAN_DAYA
  PELANGI_INDAH
  MELAKA
  SIMPANG_RENGGAM
  OTHERS
}

enum RegistrationStatus {
  PENDING_FOR_PAYMENT // waiting for payment
  PENDING_FOR_REVIEW  // admin will review
  PAYMENT_REJECTED    // payment proof invalid
  SEAT_SECURED        // once payment done
  CONTACT_ADMIN       // issue with registration
}

enum TicketType {
  ADULT
  KIDS
}

// ------------------------------------------------------
// Models
// ------------------------------------------------------

model Attendee {
  id            String         @id @default(uuid())
  name          String
  email         String
  phone         String
  outreach      OutreachLocation
  registrations Registration[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Registration {
  id            String             @id @default(uuid())
  attendee      Attendee           @relation(fields: [attendeeId], references: [id])
  attendeeId    String
  adultTickets  Int                @default(0)
  kidsTickets   Int                @default(0)
  totalAmount   Decimal            @db.Decimal(10, 2)
  status        RegistrationStatus @default(PENDING_FOR_PAYMENT)
  receiptUrl    String?            // URL for uploaded bank receipt
  payLater      Boolean            @default(false)
  orderNumber   Int                @unique @default(autoincrement())
  qrCodeUrl     String?            // Unified QR code for the entire registration
  tickets       Ticket[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Ticket {
  id             String       @id @default(uuid())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  ticketType     TicketType
  qrCodeUrl      String?      // Unique QR code image URL or encoded string
  scanned        Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Single-row table to handle admin capacity updates & dynamic prices
model AdminConfig {
  id                   Int      @id @default(1) 
  adultCapacity        Int      @default(300)
  kidsCapacity         Int      @default(100)
  isEarlyBird          Boolean  @default(true)
  adultPriceEarlyBird  Decimal  @default(0) @db.Decimal(10, 2)
  kidsPriceEarlyBird   Decimal  @default(0) @db.Decimal(10, 2)
  adultPriceRegular    Decimal  @default(0) @db.Decimal(10, 2)
  kidsPriceRegular     Decimal  @default(0) @db.Decimal(10, 2)
  earlyBirdEndDate     DateTime?
  updatedAt            DateTime @updatedAt
}

// ------------------------------------------------------
// Settings & Templates
// ------------------------------------------------------

model EmailSettings {
  id        Int      @id @default(1)
  host      String   @default("smtp.gmail.com")
  port      Int      @default(465)
  username  String?
  password  String?
  fromName  String   @default("REVIVAL Team")
  fromEmail String?
  updatedAt DateTime @updatedAt
}

enum TemplateType {
  INVOICE
  E_TICKET
  REMINDER
}

model EmailTemplate {
  id        String       @id @default(uuid())
  type      TemplateType @unique
  subject   String
  bodyHtml  String
  updatedAt DateTime     @updatedAt
}

// ------------------------------------------------------
// Logging
// ------------------------------------------------------

model EmailLog {
  id        String   @id @default(uuid())
  to        String
  subject   String
  status    String   // "SENT" or "FAILED"
  error     String?  // Stack trace or error message
  createdAt DateTime @default(now())
}

model ReportSettings {
  id            Int      @id @default(1)
  enabled       Boolean  @default(false)
  emails        String   @default("") // Comma-separated list of emails
  frequencyDays Int      @default(3)
  sendTime      String   @default("08:00") // 24-hour format HH:mm
  lastSentAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

